# General-purpose NovaDev example:
# use normal programming features to print starter app declarations.

let projects = [
    {
        name: "FreshCart",
        mode: "ecommerce",
        title: "FreshCart Store"
    },
    {
        name: "BuildRight",
        mode: "construction",
        title: "BuildRight Projects"
    },
    {
        name: "CareDesk",
        mode: "supportdesk",
        title: "CareDesk Tickets"
    }]

function entityFor(mode) {
    if mode == "ecommerce" {
        return "Product"
    } elif mode == "construction" {
        return "Lead"
    } elif mode == "supportdesk" {
        return "Ticket"
    }
    return "Item"
}

function pageTypeFor(mode) {
    if mode == "ecommerce" {
        return "catalog"
    } elif mode == "construction" {
        return "marketing"
    } elif mode == "supportdesk" {
        return "dashboard"
    }
    return "custom"
}

function printStarter(project) {
    let entity = entityFor(project.mode)
    let pageType = pageTypeFor(project.mode)

    print("app " + project.name + " {")
    print("    project {")
    print("        frontend Vue")
    print("        backend Flask")
    print("        database SQLite")
    print("        structure VueFlask")
    print("        styling Tailwind")
    print("        mode " + project.mode)
    print("    }")
    print("")
    print("    table " + entity + " {")
    print("        id auto")
    print("        name text")
    print("        status text")
    print("    }")
    print("")
    print("    page Home {")
    print("        type " + pageType)
    print("        hero {")
    print("            title \"" + project.title + "\"")
    print("            subtitle \"Generated by NovaDev general-purpose code\"")
    print("        }")
    print("        section Records from " + entity)
    print("    }")
    print("}")
    print("")
}

for project in projects {
    printStarter(project)
}
