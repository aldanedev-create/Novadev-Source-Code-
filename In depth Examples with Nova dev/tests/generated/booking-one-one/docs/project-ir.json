{
  "name": "BookingOneOne",
  "mode": "booking",
  "frontend": "Vue",
  "backend": "Flask",
  "database": "SQLite",
  "styling": "Tailwind",
  "style": {
    "system": "Tailwind",
    "mode": "booking",
    "primary": "#0891b2",
    "accent": "#164e63",
    "surface": "#ecfeff",
    "text": "#111827",
    "muted": "#64748b",
    "radius": "medium",
    "density": "comfortable",
    "font": "Inter",
    "shell": "min-h-screen bg-[var(--nova-surface)] text-[var(--nova-text)] lg:grid lg:grid-cols-[17rem_1fr]",
    "sidebar": "bg-slate-950 text-white p-5 flex flex-col gap-5",
    "topbar": "min-h-16 border-b border-slate-200 bg-white/90 px-6 flex items-center justify-between gap-4 backdrop-blur",
    "page": "p-6 grid content-start gap-5",
    "hero": "min-h-72 rounded-nova bg-gradient-to-br from-cyan-950 via-sky-700 to-teal-400 p-8 text-white grid content-end gap-4",
    "panel": "overflow-hidden rounded-nova border border-slate-200 bg-white shadow-sm",
    "card": "rounded-nova border border-slate-200 bg-white p-5 shadow-sm",
    "button": "inline-flex min-h-10 items-center justify-center rounded-nova bg-[var(--nova-primary)] px-4 py-2 font-semibold text-white hover:opacity-90",
    "ghost_button": "inline-flex min-h-10 items-center justify-center rounded-nova bg-slate-100 px-4 py-2 font-semibold text-slate-700 hover:bg-slate-200",
    "input": "min-h-10 rounded-nova border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--nova-primary)]",
    "table": "w-full border-collapse text-left text-sm",
    "badge": "rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700",
    "notes": [
      "style system: Tailwind",
      "mode profile: booking",
      "no theme overrides",
      "css radius: 0.75rem"
    ]
  },
  "entities": [
    {
      "name": "Service",
      "fields": [
        {
          "name": "id",
          "type": "auto",
          "attributes": []
        },
        {
          "name": "name",
          "type": "text",
          "attributes": []
        },
        {
          "name": "duration",
          "type": "int",
          "attributes": []
        }
      ]
    },
    {
      "name": "Customer",
      "fields": [
        {
          "name": "id",
          "type": "auto",
          "attributes": []
        },
        {
          "name": "name",
          "type": "text",
          "attributes": []
        },
        {
          "name": "email",
          "type": "email",
          "attributes": []
        }
      ]
    },
    {
      "name": "Booking",
      "fields": [
        {
          "name": "id",
          "type": "auto",
          "attributes": []
        },
        {
          "name": "customerName",
          "type": "text",
          "attributes": []
        },
        {
          "name": "serviceName",
          "type": "text",
          "attributes": []
        },
        {
          "name": "status",
          "type": "text",
          "attributes": []
        }
      ]
    }
  ],
  "pages": [
    {
      "name": "Bookings",
      "title": "Bookings",
      "type": "booking",
      "route": "/bookings",
      "sections": [
        {
          "name": "Services",
          "source": "Service"
        }
      ],
      "hero": {
        "title": "Booking Calendar",
        "subtitle": "Booking-specific workflow example"
      },
      "components": [
        {
          "kind": "type",
          "name": "booking",
          "props": {}
        },
        {
          "kind": "hero",
          "name": "",
          "props": {
            "title": "Booking Calendar",
            "subtitle": "Booking-specific workflow example"
          }
        },
        {
          "kind": "section",
          "name": "Services",
          "props": {
            "source": "Service"
          }
        },
        {
          "kind": "form",
          "name": "Booking",
          "props": {
            "fields": [
              "customerName",
              "serviceName",
              "status"
            ],
            "submit": "Book"
          }
        }
      ]
    }
  ],
  "workflows": [
    {
      "name": "CreateBooking",
      "input": "Booking",
      "uses": "BookingTools.confirm",
      "creates": [
        "Booking"
      ],
      "steps": [
        {
          "kind": "input",
          "name": "Booking",
          "props": {}
        },
        {
          "kind": "uses",
          "name": "BookingTools.confirm",
          "props": {}
        },
        {
          "kind": "creates",
          "name": "Booking",
          "props": {}
        }
      ]
    }
  ],
  "modules": [
    {
      "name": "BookingTools",
