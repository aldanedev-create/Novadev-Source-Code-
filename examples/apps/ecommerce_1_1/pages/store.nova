page StoreFront {
    type catalog
    hero {
        title "Nova Shop"
        subtitle "Project-specific e-commerce generated by NovaDev 1.1"
        action "Checkout" to "/checkout"
    }
    section Products from Product
    catalog Product {
        fields name, price, stock
        actions view, add_to_cart
    }
}

page Checkout {
    type checkout
    checkout Order {
        fields customerName, total, status
        submit "Place Order"
    }
}

export StoreFront
